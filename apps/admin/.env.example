# Admin gateway (Better Auth + прокси к generator) — порт по умолчанию 3000
# Разрешённые origin фронтов (через запятую):
#   admin-web :3001, studio-web :3002, persons-web :3004

DATABASE_URL=postgresql://postgres:password@localhost:5432/generator
PORT=3000
NODE_ENV=development

# Auth — один секрет для всех сервисов (admin, studio, generator, persons)
BETTER_AUTH_SECRET=replace-with-a-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3004

GENERATOR_API_URL=http://localhost:3005
STUDIO_API_URL=http://localhost:3006

# Объектное хранилище (для asset releases, pipeline, worker → датасеты в fal/cerebrium)
# Имя бакета в панели Hetzner; endpoint — полный URL или только хост (добавится https://).
# Допустимы пары ключей: S3_ACCESS_KEY_ID + S3_SECRET_ACCESS_KEY или S3_ACCESS_KEY + S3_SECRET_KEY.
# S3_BUCKET=generator
# S3_REGION=hel1
# S3_ENDPOINT=hel1.your-objectstorage.com
# S3_ACCESS_KEY=replace-with-object-storage-access-key
# S3_SECRET_KEY=replace-with-object-storage-secret
# S3_PUBLIC_URL=https://hel1.your-objectstorage.com/generator

PERSONS_API_URL=http://localhost:3003
TRAINING_CONTROL_TOKEN=local-training-control-token
ASSET_PUBLIC_BASE_URL=https://assets.example.com

# fal.ai ZIB LoRA training
# FAL_KEY=your-fal-api-key

# Cerebrium LoRA training (альтернатива fal.ai)
# CEREBRIUM_API_KEY=eyJ...
# CEREBRIUM_PROJECT_ID=p-xxxxxxxx
# CEREBRIUM_REGION=aws.us-east-1

# CivitAI API token for model downloads
# CIVITAI_API_TOKEN=your-civitai-api-token

REDIS_URL=redis://localhost:6381
