# Admin gateway (Better Auth + прокси к generator) — порт по умолчанию 3000
# Разрешённые origin фронтов (через запятую):
#   admin-web :3001, studio-web :3002, persons-web :3004

DATABASE_URL=postgresql://postgres:password@localhost:5432/generator
PORT=3000
NODE_ENV=development

# Auth — один секрет для всех сервисов (admin, studio, generator, persons)
BETTER_AUTH_SECRET=replace-with-a-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000
# Для production с несколькими subdomain:
# BETTER_AUTH_COOKIE_DOMAIN=gen.example.com

CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3004

GENERATOR_API_URL=http://localhost:3005
STUDIO_API_URL=http://localhost:3006

# Объектное хранилище — обязательно для админки (asset releases, pipeline, worker
# датасеты в fal/cerebrium, кэширование внешних LoRA). Имя бакета в панели Hetzner;
# endpoint — полный URL или только хост (добавится https://).
# Допустимые алиасы пар ключей: S3_ACCESS_KEY_ID + S3_SECRET_ACCESS_KEY либо
# S3_ACCESS_KEY + S3_SECRET_KEY. Публичная база (S3_PUBLIC_BASE_URL) обязательна для
# раздачи артефактов; алиасы S3_PUBLIC_URL и ASSET_PUBLIC_BASE_URL поддерживаются
# исключительно ради совместимости с переменными окружения хостинга.
S3_BUCKET=generator
S3_REGION=hel1
S3_ENDPOINT=hel1.your-objectstorage.com
S3_ACCESS_KEY_ID=replace-with-object-storage-access-key
S3_SECRET_ACCESS_KEY=replace-with-object-storage-secret
S3_PUBLIC_BASE_URL=https://hel1.your-objectstorage.com/generator

PERSONS_API_URL=http://localhost:3003
TRAINING_CONTROL_TOKEN=local-training-control-token

# fal.ai ZIB LoRA training
# FAL_KEY=your-fal-api-key

# LoRA training provider switch: "fal" (default, fal-ai/z-image-trainer) or
# "runpod" (экспериментальный ai-toolkit на RunPod serverless).
TRAINING_PROVIDER=fal

# RunPod ai-toolkit (serverless) — экспериментально.
# RUNPOD_API_KEY=rpa_xxxxxxxxxxxxxxxxxxxx
# RUNPOD_AI_TOOLKIT_ENDPOINT_ID=replace-with-runpod-serverless-endpoint
# RUNPOD_API_BASE_URL=https://api.runpod.ai/v2
# RUNPOD_AI_TOOLKIT_TIMEOUT_MS=7200000
# RUNPOD_AI_TOOLKIT_POLL_MS=30000
# RUNPOD_AI_TOOLKIT_BASE_MODEL=z-image  # z-image | flux-dev | flux-schnell | flux2-dev | sdxl | qwen-image

# External model hub tokens for private/gated LoRA downloads
# CIVITAI_API_KEY=your-civitai-api-key
# HUGGINGFACE_TOKEN=hf_your-read-token

REDIS_URL=redis://localhost:6381
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=generator
