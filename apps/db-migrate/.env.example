# db-migrate — применяет Drizzle-миграции под advisory lock и держит
# health/ready/status эндпоинты для Coolify.

# Подключение к БД, такое же как у admin-api/studio-api.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# HTTP-порт сервиса (использует Coolify health-check).
PORT=3010

# Опциональные тайминги ожидания БД при старте (мс).
# DB_READY_TIMEOUT_MS=60000
# DB_RETRY_INTERVAL_MS=2000

# ID advisory lock, под которым выполняется migrate(). Должен совпадать
# во всех инстансах, чтобы избежать гонок при параллельных деплоях.
# MIGRATION_LOCK_ID=727263011

# Опциональный bearer-токен для POST /api/migrate (повторный прогон без редеплоя).
# Если пусто — эндпоинт открыт всем, кто видит сервис в сети coolify.
# MIGRATE_TRIGGER_TOKEN=replace-me
