# Generator API — порт по умолчанию 3005
# Шлюзы admin (3000) и studio (3006) ходят сюда через GENERATOR_API_URL.

DATABASE_URL=postgresql://postgres:password@localhost:5435/generator
PORT=3005
NODE_ENV=development
REDIS_URL=redis://localhost:6381
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=generator

# Auth — тот же секрет, что у admin/studio/persons (единая сессия)
BETTER_AUTH_SECRET=replace-with-a-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3005
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3004
GENERATOR_INTERNAL_TOKEN=local-generator-internal-token

# fal.ai inference provider
FAL_KEY=fal_replace-with-fal-api-key

# Replicate inference provider for replicate-fooocus-sdxl (optional).
# Uses mrhan1993/fooocus-api on Replicate.
# REPLICATE_API_TOKEN=r8_replace-with-replicate-token

# RunPod inference provider for runpod-fooocus-sdxl (optional).
# Endpoint must be a queue-based Serverless worker that accepts the workflow
# payload described in tools/runpod-fooocus/README.md.
# RUNPOD_API_KEY=rpa_replace-with-runpod-api-key
# RUNPOD_FOOOCUS_ENDPOINT_ID=replace-with-runpod-serverless-endpoint

# Объектное хранилище — обязательно. Все артефакты выкачиваются провайдерами (например,
# fal.ai) и пересохраняются во внутренний S3, поэтому конфигурация должна быть полной.
# Алиасы пары ключей: S3_ACCESS_KEY_ID + S3_SECRET_ACCESS_KEY либо S3_ACCESS_KEY +
# S3_SECRET_KEY. Публичная база (S3_PUBLIC_BASE_URL) обязательна и определяет URL,
# по которому будут раздаваться сохранённые артефакты.
S3_BUCKET=generator
S3_REGION=hel1
S3_ENDPOINT=hel1.your-objectstorage.com
S3_ACCESS_KEY_ID=replace-with-object-storage-access-key
S3_SECRET_ACCESS_KEY=replace-with-object-storage-secret
S3_PUBLIC_BASE_URL=https://hel1.your-objectstorage.com/generator
