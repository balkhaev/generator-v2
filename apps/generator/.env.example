# Generator API — порт по умолчанию 3005
# Шлюзы admin (3000) и studio (3006) ходят сюда через GENERATOR_API_URL.

DATABASE_URL=postgresql://postgres:password@localhost:5435/generator
PORT=3005
NODE_ENV=development
REDIS_URL=redis://localhost:6381
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=generator

# Auth — тот же секрет, что у admin/studio/persons (единая сессия)
BETTER_AUTH_SECRET=replace-with-a-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3005
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3004
GENERATOR_INTERNAL_TOKEN=local-generator-internal-token

# Civitai inference provider for civitai-* workflows (optional).
# Uses Civitai orchestration /v1/consumer/jobs.
# CIVITAI_API_KEY=replace-with-civitai-api-key

# fal.ai inference provider
FAL_KEY=fal_replace-with-fal-api-key

# Replicate inference provider for replicate-fooocus-sdxl (optional).
# Uses mrhan1993/fooocus-api on Replicate.
# REPLICATE_API_TOKEN=r8_replace-with-replicate-token

# RunPod inference provider for runpod-fooocus-sdxl (optional).
# Endpoint must be a queue-based Serverless worker that accepts the workflow
# payload described in tools/runpod-fooocus/README.md.
#
# Чтобы прогрев был стабильным, в RunPod console (Serverless → Edit endpoint)
# или через `packages/runpod/scripts/create-serverless-endpoints.ts`:
#   - Active workers ≥ 1   — единственный способ убрать cold start гарантировано
#                            (WORKERS_MIN=1 в скрипте, defaults к 1)
#   - FlashBoot = ON       — восстановление warm worker'а за 1-3s
#   - Idle timeout 300s+   — worker не засыпает между jobs, burst переиспользует
#                            warm pool (IDLE_TIMEOUT_SEC=300)
#   - GPU priority list    — 5-10 типов GPU для capacity fallback (GPU_PRIORITY)
#   - Auto-scaling QUEUE_DELAY=4 — поднимает доп. worker если queue висит >4s
# SDK сам не меняет endpoint config; проверка состояния — health-serverless.ts.
#
# Generator-side тюнинг (apps/generator):
#   - GENERATOR_STUCK_QUEUE_RESUBMIT_AFTER_MS=900000  (15 мин — default)
#     Защищает LTX workflow с длинным cold-start от cancel→resubmit loop.
#   - GENERATOR_STUCK_QUEUE_FAIL_AFTER_MS=1800000     (30 мин — default)
#
# RUNPOD_API_KEY=rpa_replace-with-runpod-api-key
# RUNPOD_FOOOCUS_ENDPOINT_ID=replace-with-runpod-serverless-endpoint
# RUNPOD_FOOOCUS_ENABLE_WARMUP=false  # true только если active workers ≥ 1 невозможен
#
# LTX 2.3 serverless (admin DB template mode=serverless, endpoint hr1a398xx75thx):
# RUNPOD_LTX23_ENABLE_WARMUP=true       # default true — backup ping если worker умер
# RUNPOD_LTX23_WARMUP_INTERVAL_MS=180000
# RUNPOD_SERVERLESS_WARMUP_ENABLED=true # false = отключить все warmup runners в worker
# RUNPOD_LTX23_SERVERLESS_ENDPOINT_ID=hr1a398xx75thx  # для CLI warmup-serverless.ts

# RunPod disposable Pod inference for runpod-ltx-2-3 image-to-video (optional).
# Использует pre-provisioned RunPod template `p4f6rm9tb4` (`ls250824/run-comfyui-ltx`)
# с поднятой ComfyUI, Lora Manager API и предзагруженными моделями LTX 2.3.
# Pod общается с агентом по HTTP (auth через ComfyUI-Login), артефакт сохраняется в S3.
# RUNPOD_API_KEY=rpa_replace-with-runpod-api-key
# RUNPOD_REST_API_BASE_URL=https://rest.runpod.io/v1
# RUNPOD_LTX23_POD_TEMPLATE_ID=p4f6rm9tb4
# RUNPOD_LTX23_POD_IMAGE_NAME=ls250824/run-comfyui-ltx:28042026
# RUNPOD_LTX23_POD_GPU_TYPE_IDS=NVIDIA RTX A6000,NVIDIA A40,NVIDIA H100 80GB HBM3
# RUNPOD_LTX23_POD_CONTAINER_DISK_GB=15
# RUNPOD_LTX23_POD_VOLUME_GB=90
# RUNPOD_LTX23_POD_CLOUD_TYPE=SECURE
# RUNPOD_LTX23_POD_TIMEOUT_MS=3600000
# CIVITAI_API_KEY=replace-with-civitai-api-key
# HF_TOKEN=hf_replace-with-huggingface-token

# Объектное хранилище — обязательно. Все артефакты выкачиваются провайдерами (например,
# fal.ai) и пересохраняются во внутренний S3, поэтому конфигурация должна быть полной.
# Алиасы пары ключей: S3_ACCESS_KEY_ID + S3_SECRET_ACCESS_KEY либо S3_ACCESS_KEY +
# S3_SECRET_KEY. Публичная база (S3_PUBLIC_BASE_URL) обязательна и определяет URL,
# по которому будут раздаваться сохранённые артефакты.
S3_BUCKET=generator
S3_REGION=hel1
S3_ENDPOINT=hel1.your-objectstorage.com
S3_ACCESS_KEY_ID=replace-with-object-storage-access-key
S3_SECRET_ACCESS_KEY=replace-with-object-storage-secret
S3_PUBLIC_BASE_URL=https://hel1.your-objectstorage.com/generator
