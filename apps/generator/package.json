{
  "name": "generator",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile generator",
    "dev": "bun run --hot src/index.ts",
    "dev:worker": "bun run --hot src/worker.ts",
    "start": "bun run dist/index.mjs",
    "start:worker": "bun run dist/worker.mjs"
  },
  "dependencies": {
    "@generator/auth": "workspace:*",
    "@generator/contracts": "workspace:*",
    "@generator/db": "workspace:*",
    "@generator/env": "workspace:*",
    "@generator/events": "workspace:*",
    "@generator/http": "workspace:*",
    "@generator/queue": "workspace:*",
    "@generator/runpod": "workspace:*",
    "@generator/storage": "workspace:*",
    "@generator/workflows": "workspace:*",
    "hono": "^4.8.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@generator/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.16.5",
    "typescript": "^5"
  }
}
