# Persons API — порт по умолчанию 3003

DATABASE_URL=postgresql://postgres:password@localhost:5435/generator
PORT=3003
NODE_ENV=development

# Auth — тот же секрет, что у admin/studio/generator (единая сессия)
BETTER_AUTH_SECRET=replace-with-a-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3003

# Origin persons-web (next dev --port 3004)
CORS_ORIGIN=http://localhost:3004
CORS_ORIGINS=http://localhost:3004
PERSONS_BASE_URL=http://localhost:3003

# Опционально: studio API как источник импортируемых runs/scenarios
PERSONS_OPERATOR_URL=http://localhost:3006
# PERSONS_ADMIN_URL — нужен ТОЛЬКО для HTTP-фолбэка тренировки LoRA, когда
# Kafka-event-bus отключён. LoRA registry читается напрямую из общей БД.
PERSONS_ADMIN_URL=http://localhost:3000
GENERATOR_INTERNAL_TOKEN=local-generator-internal-token
GENERATOR_CALLBACK_TOKEN=local-generator-callback-token
TRAINING_CONTROL_TOKEN=local-training-control-token
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=generator

# Workflow для генерации аватара и LoRA-генерации
# Cerebrium: cerebrium-zib-dpo / cerebrium-zib-dpo-lora
# Fal: fal-zimage-turbo (LoRA url передаётся опционально через сценарий)
PERSONS_DEFAULT_AVATAR_WORKFLOW=cerebrium-zib-dpo
PERSONS_DEFAULT_LORA_WORKFLOW=cerebrium-zib-dpo-lora

# xAI / Grok ключ для Enhance-режима генерации референсов
XAI_API_KEY=
