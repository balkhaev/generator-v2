# Studio gateway — порт по умолчанию 3006

DATABASE_URL=postgresql://postgres:password@localhost:5432/generator
PORT=3006
NODE_ENV=development

# Auth — один секрет для всех сервисов (admin, studio, generator, persons)
BETTER_AUTH_SECRET=replace-with-a-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3006

# Только origin studio-web
CORS_ORIGINS=http://localhost:3002

GENERATOR_API_URL=http://localhost:3005
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=generator

# Admin API — используется для проксирования LoRA registry в /api/loras.
# Без него Compose не сможет показать список LoRA.
ADMIN_API_URL=http://localhost:3000
TRAINING_CONTROL_TOKEN=replace-with-shared-internal-token

# Опционально: ключ для prompt enhance (xAI Grok). Без него /api/enhance-prompt вернёт 503.
# XAI_API_KEY=

# Объектное хранилище — обязательно. Все input-assets грузятся напрямую в S3.
# Те же алиасы, что в admin: S3_ACCESS_KEY_ID + S3_SECRET_ACCESS_KEY или
# S3_ACCESS_KEY + S3_SECRET_KEY; endpoint с https или только хост.
S3_BUCKET=generator
S3_REGION=hel1
S3_ENDPOINT=hel1.your-objectstorage.com
S3_ACCESS_KEY_ID=replace-with-object-storage-access-key
S3_SECRET_ACCESS_KEY=replace-with-object-storage-secret
S3_PUBLIC_BASE_URL=https://hel1.your-objectstorage.com/generator
