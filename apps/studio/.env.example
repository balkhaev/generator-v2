# Studio gateway — порт по умолчанию 3006

DATABASE_URL=postgresql://postgres:password@localhost:5432/generator
PORT=3006
NODE_ENV=development

# Auth — один секрет для всех сервисов (admin, studio, generator, persons)
BETTER_AUTH_SECRET=replace-with-a-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3006

# Только origin studio-web
CORS_ORIGINS=http://localhost:3002

GENERATOR_API_URL=http://localhost:3005
# Без токена generator-api отвечает 401 на POST /api/executions
GENERATOR_INTERNAL_TOKEN=local-generator-internal-token
GENERATOR_CALLBACK_TOKEN=local-generator-callback-token
# Серверный URL persons для GET /api/persons/:id при запуске рана с Cast LoRA.
# Локально часто совпадает с NEXT_PUBLIC_PERSONS_API_URL в studio-web.
# В Coolify / Docker-сети лучше внутренний хост сервиса, например http://persons-api:3003
# (см. docs/coolify-studio-persons-lora.md и docker/README.md).
PERSONS_API_URL=http://localhost:3003
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=generator

# LoRA registry читается напрямую из общей БД (DATABASE_URL).

# Centralised runtime-config: studio-api fetches enhance provider+credentials
# from admin-api /api/internal/runtime-config/prompt-enhance. Без этих двух
# переменных studio падает на env-fallback ниже (XAI_API_KEY / OPENROUTER_*).
# Token must match admin-api's RUNTIME_CONFIG_INTERNAL_TOKEN.
ADMIN_API_URL=http://localhost:3000
RUNTIME_CONFIG_INTERNAL_TOKEN=replace-with-32-byte-hex-secret
# Used by Studio LoRA import proxy when it calls admin-api /api/admin/loras.
# Must match admin-api TRAINING_CONTROL_TOKEN in production.
TRAINING_CONTROL_TOKEN=local-training-control-token

# Fallback prompt-enhance keys, used only when admin-api is unreachable:
# XAI_API_KEY (Grok) или OPENROUTER_API_KEY + OPENROUTER_MODEL.
# Алиасы XAI: GROK_API_KEY, XAI_KEY, XAI_API_TOKEN.

# Объектное хранилище — обязательно. Все input-assets грузятся напрямую в S3.
# Те же алиасы, что в admin: S3_ACCESS_KEY_ID + S3_SECRET_ACCESS_KEY или
# S3_ACCESS_KEY + S3_SECRET_KEY; endpoint с https или только хост.
S3_BUCKET=generator
S3_REGION=hel1
S3_ENDPOINT=hel1.your-objectstorage.com
S3_ACCESS_KEY_ID=replace-with-object-storage-access-key
S3_SECRET_ACCESS_KEY=replace-with-object-storage-secret
S3_PUBLIC_BASE_URL=https://hel1.your-objectstorage.com/generator
