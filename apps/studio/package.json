{
  "name": "studio",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile studio",
    "dev": "bun run --hot src/index.ts",
    "repair": "bun run src/worker.ts",
    "repair:watch": "RECONCILE_WATCH=true bun run --hot src/worker.ts",
    "start": "bun run dist/index.mjs",
    "start:repair": "bun run dist/worker.mjs"
  },
  "dependencies": {
    "@generator/asset-release-presets": "workspace:*",
    "@generator/auth": "workspace:*",
    "@generator/contracts": "workspace:*",
    "@generator/db": "workspace:*",
    "@generator/env": "workspace:*",
    "@generator/generator-client-server": "workspace:*",
    "@generator/http": "workspace:*",
    "@generator/workflows": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.8.2"
  },
  "devDependencies": {
    "@generator/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.16.5",
    "typescript": "^5"
  }
}
